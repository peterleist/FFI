generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Single-row JSON snapshot – holds the entire app state for one user.
// Simple and robust for a personal finance app.
model AppSnapshot {
  id        String   @id @default("singleton")
  data      Json
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("app_snapshots")
}

model User {
  id               String    @id @default(uuid())
  email            String    @unique
  name             String?
  fireGoalAmount   Decimal?  @map("fire_goal_amount") @db.Decimal(15, 2)
  fireTargetAge    Int?      @map("fire_target_age")
  monthlyExpenses  Decimal?  @map("monthly_expenses") @db.Decimal(15, 2)
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  accounts         Account[]
  categories       Category[]
  transactions     Transaction[]
  recurringItems   RecurringItem[]

  @@map("users")
}

model Account {
  id           String      @id @default(uuid())
  userId       String      @map("user_id")
  name         String
  type         AccountType
  tbszYear     Int?        @map("tbsz_year")
  balance      Decimal     @default(0) @db.Decimal(15, 2)
  currency     String      @default("HUF")
  isActive     Boolean     @default(true) @map("is_active")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  positions    InvestmentPosition[]

  @@map("accounts")
}

model Category {
  id            String       @id @default(uuid())
  userId        String       @map("user_id")
  name          String
  type          CategoryType
  icon          String?
  color         String?
  monthlyBudget Decimal?     @map("monthly_budget") @db.Decimal(15, 2)
  createdAt     DateTime     @default(now()) @map("created_at")

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions  Transaction[]
  recurringItems RecurringItem[]

  @@map("categories")
}

model Transaction {
  id            String            @id @default(uuid())
  userId        String            @map("user_id")
  accountId     String            @map("account_id")
  categoryId    String?           @map("category_id")
  amount        Decimal           @db.Decimal(15, 2)
  date          DateTime          @db.Date
  description   String?
  note          String?
  isRecurring   Boolean           @default(false) @map("is_recurring")
  recurringId   String?           @map("recurring_id")
  status        TransactionStatus @default(CONFIRMED)
  importBatchId String?           @map("import_batch_id")
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")

  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  account       Account           @relation(fields: [accountId], references: [id], onDelete: Cascade)
  category      Category?         @relation(fields: [categoryId], references: [id])

  @@map("transactions")
}

model RecurringItem {
  id          String       @id @default(uuid())
  userId      String       @map("user_id")
  categoryId  String?      @map("category_id")
  name        String
  amount      Decimal      @db.Decimal(15, 2)
  type        CategoryType
  frequency   Frequency
  startDate   DateTime     @map("start_date") @db.Date
  endDate     DateTime?    @map("end_date") @db.Date
  dayOfMonth  Int?         @map("day_of_month")
  isActive    Boolean      @default(true) @map("is_active")
  createdAt   DateTime     @default(now()) @map("created_at")

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  category    Category?    @relation(fields: [categoryId], references: [id])

  @@map("recurring_items")
}

model InvestmentPosition {
  id              String    @id @default(uuid())
  accountId       String    @map("account_id")
  ticker          String
  name            String?
  quantity        Decimal   @db.Decimal(18, 6)
  averageBuyPrice Decimal   @map("average_buy_price") @db.Decimal(15, 4)
  currentPrice    Decimal?  @map("current_price") @db.Decimal(15, 4)
  currency        String    @default("HUF")
  tags            String[]
  updatedAt       DateTime  @updatedAt @map("updated_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  account         Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  trades          InvestmentTrade[]

  @@map("investment_positions")
}

model InvestmentTrade {
  id         String     @id @default(uuid())
  positionId String     @map("position_id")
  type       TradeType
  quantity   Decimal    @db.Decimal(18, 6)
  price      Decimal    @db.Decimal(15, 4)
  fee        Decimal?   @default(0) @db.Decimal(15, 4)
  date       DateTime   @db.Date
  note       String?
  createdAt  DateTime   @default(now()) @map("created_at")

  position   InvestmentPosition @relation(fields: [positionId], references: [id], onDelete: Cascade)

  @@map("investment_trades")
}

enum AccountType {
  BANK
  CASH
  ALLAMPAPIR
  TBSZ
  BROKER
}

enum CategoryType {
  INCOME
  EXPENSE
  TRANSFER
}

enum TransactionStatus {
  PENDING
  CONFIRMED
}

enum Frequency {
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

enum TradeType {
  BUY
  SELL
}
